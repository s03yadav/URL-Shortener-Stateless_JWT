<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Liquid Glass URL Shortener</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a, #1e1b4b, #311042);
            overflow: hidden;
            position: relative;
        }

        /* Liquid Background Blobs */
        .blob {
            position: absolute;
            background: linear-gradient(180deg, rgba(99, 102, 241, 0.6) 0%, rgba(168, 85, 247, 0.6) 100%);
            border-radius: 50%;
            filter: blur(80px);
            z-index: 1;
            animation: float 10s infinite ease-in-out alternate;
        }

        .blob-1 {
            width: 400px;
            height: 400px;
            top: -10%;
            left: -10%;
        }

        .blob-2 {
            width: 500px;
            height: 500px;
            bottom: -20%;
            right: -10%;
            animation-delay: -5s;
        }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(80px, 50px) scale(1.2); }
        }

        /* Glassmorphism Container */
        .glass-container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 550px;
            padding: 3rem 2rem;
            margin: 20px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.3),
                        inset 0 1px 2px rgba(255, 255, 255, 0.2);
            text-align: center;
        }

        h1 {
            color: #ffffff;
            font-size: 2.2rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            letter-spacing: -0.5px;
        }

        p.subtitle {
            color: #cbd5e1;
            font-size: 0.95rem;
            margin-bottom: 2.5rem;
        }

        /* Input Wrapper & Styling */
        .input-group {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .input-group i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.5);
            font-size: 1.1rem;
            transition: color 0.3s;
        }

        .input-field {
            width: 100%;
            padding: 15px 15px 15px 45px;
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            outline: none;
            color: #ffffff;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .input-field:focus {
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(168, 85, 247, 0.6);
            box-shadow: 0 0 15px rgba(168, 85, 247, 0.3);
        }

        .input-field:focus + i {
            color: #a855f7;
        }

        /* Button Layout Action Row */
        .action-row {
            display: flex;
            gap: 12px;
            width: 100%;
        }

        /* Submit Button */
        .submit-btn {
            flex: 2;
            padding: 15px;
            background: linear-gradient(90deg, #6366f1, #a855f7);
            border: none;
            border-radius: 12px;
            color: #ffffff;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.3s;
            box-shadow: 0 4px 15px rgba(168, 85, 247, 0.4);
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(168, 85, 247, 0.6);
        }

        /* History Button Styling */
        .history-btn {
            flex: 1;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            padding: 15px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 12px;
            color: #ffffff;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .history-btn:hover {
            background: rgba(255, 255, 255, 0.18);
            border-color: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
        }

        .submit-btn:active, .history-btn:active {
            transform: translateY(1px);
        }

        /* Error Section (Liquid Glass Look with Red Tint) */
        .error-container {
            margin-top: 2rem;
            padding: 1.2rem;
            background: rgba(239, 68, 68, 0.1); /* Soft Crimson Red */
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 14px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-align: left;
            animation: fadeIn 0.5s ease forwards;
        }

        .error-container i {
            color: #f87171;
            font-size: 1.2rem;
        }

        .error-msg {
            color: #fca5a5;
            font-size: 0.95rem;
            font-weight: 400;
        }

        /* Result Section (Liquid Glass Look) */
        .result-container {
            margin-top: 2rem;
            padding: 1.2rem;
            background: rgba(255, 255, 255, 0.03);
            border: 1px dashed rgba(255, 255, 255, 0.2);
            border-radius: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: fadeIn 0.5s ease forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .short-url {
            color: #38bdf8;
            font-weight: 600;
            text-decoration: none;
            font-size: 1.1rem;
            word-break: break-all;
            text-align: left;
            padding-right: 10px;
        }

        .short-url:hover {
            text-decoration: underline;
        }

        .copy-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff;
            padding: 8px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .copy-btn:hover {
            background: #ffffff;
            color: #1e1b4b;
        }
    </style>
</head>
<body>

    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

    <div class="glass-container">
        <h1>SnapURL</h1>
        <p class="subtitle">Shorten your long links instantly into clean, microscopic URLs.</p>

        <form action="/home" method="POST">
            <div class="input-group">
                <input 
                    type="text" 
                    name="url" 
                    class="input-field" 
                    placeholder="Paste your long URL here..." 
                    required
                >
                <i class="fa-solid fa-link"></i>
            </div>
            
            <div class="action-row">
                <button type="submit" class="submit-btn">Shorten URL</button>
                <a href="/home/history" class="history-btn">
                    <i class="fa-solid fa-history"></i> History
                </a>
            </div>
        </form>

        <% if (!error === "") { %>
            <div class="error-container">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span class="error-msg"><%= error %></span>
            </div>
        <% } %>

        <% if (url && url !== "") { %>
            <div class="result-container">
                <a href="<%= url %>" target="_blank" class="short-url" id="shortUrlText"><%= url %></a>
            </div>
        <% } %>
    </div>

</body>
</html>